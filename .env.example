# Application runtime mode. Use "production" in AWS deployments.
NODE_ENV=development

# When true, disables CloudFront signed URLs and uses S3 presigned GET URLs instead.
DEV_MODE=true

# Port the API server listens on. Lambda Web Adapter expects 8080.
PORT=3000

# Allowed CORS origin for the web app. Comma-separate multiple origins.
APP_ORIGIN=http://localhost:5173

# Base URL the frontend uses to reach the API.
API_BASE_URL=http://localhost:3000

# AWS region for all resources.
AWS_REGION=us-east-1

# AWS credentials. In Lambda/ECS, leave blank because IAM role is used instead.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# DynamoDB table name.
DYNAMODB_TABLE=ClipForgeTable

# S3 bucket for raw recordings.
VIDEO_ORIGINALS_BUCKET=clipforge-video-originals

# S3 bucket for thumbnails and future derived assets.
VIDEO_DERIVED_BUCKET=clipforge-video-derived

# S3 bucket for compiled frontend static assets.
APP_ASSETS_BUCKET=clipforge-app-assets

# CloudFront domain for video delivery. Leave blank in local dev.
CLOUDFRONT_VIDEO_DOMAIN=

# CloudFront key pair ID for signed URLs. Leave blank to use S3 presigned URLs in dev.
CLOUDFRONT_KEY_PAIR_ID=

# Base64-encoded CloudFront RSA private key PEM.
CLOUDFRONT_PRIVATE_KEY_BASE64=

# Secret used to sign JWTs. Must be at least 32 characters in production.
JWT_SECRET=replace-me-with-a-32-plus-char-secret

# Maximum allowed upload size in bytes. Default is 1GB.
MAX_UPLOAD_BYTES=1073741824

# How long presigned upload part URLs are valid, in seconds.
PRESIGNED_URL_EXPIRES_SECONDS=900

# Default multipart part size in bytes. Must be >= 5MB.
UPLOAD_PART_SIZE_BYTES=16777216
